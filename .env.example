# Copy this file to `~/.cat-in-lattice/.env` for global use,
# or to `.env` in your current project directory.

# Optional, but enough for `cat-in-lattice notice "..."` and `--slack-test-message`
CAT_IN_LATTICE_SLACK_WEBHOOK_URL=

# Optional: only needed when you want Cat-In-Lattice to read an existing Slack channel
CAT_IN_LATTICE_SLACK_TOKEN=
CAT_IN_LATTICE_SLACK_CHANNEL=
